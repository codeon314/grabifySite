---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Grabify Manager | Mastercodeon">
  <main>
    <h1 style="text-align: center; color: var(--accent-color); margin-bottom: 2rem;">Grabify Link Manager</h1>

    <div class="tabs">
      <button class="tab-btn active" data-tab="manager">Link Manager</button>
      <button class="tab-btn" data-tab="visitors">Visitors</button>
    </div>

    <!-- LINK MANAGER TAB -->
    <div id="tab-manager" class="tab-panel active">
      <div class="input-group">
        <input type="text" id="urlInput" placeholder="Enter target URL (with https://)" />
        <button id="createBtn">Create Grabify Link</button>
      </div>
      <input type="text" id="resultLink" readonly placeholder="Created link will appear here..." />

      <div class="load-section">
        <label for="loadInput">Load existing (code or URL):</label>
        <div class="input-group">
          <input type="text" id="loadInput" placeholder="Tracking code or full tracking URL" />
          <button id="loadBtn">Load</button>
        </div>
      </div>

      <div class="info-group">
        <h3>Link Information</h3>
        <div class="info-row">
          <label>Original URL:</label>
          <input type="text" id="originalUrl" readonly />
        </div>
        <div class="info-row">
          <label>New URL:</label>
          <input type="text" id="newUrl" readonly />
        </div>
        <div class="info-row">
          <label>Tracking Code:</label>
          <input type="text" id="trackingCode" readonly />
        </div>
        <div class="info-row">
          <label>Access Link:</label>
          <input type="text" id="accessLink" readonly />
        </div>
      </div>

      <div class="settings-group">
        <h3>Settings</h3>
        <div class="checkbox-grid">
          <label><input type="checkbox" id="chkSmartLogger" /> Smart Logger</label>
          <label><input type="checkbox" id="chkConsent" /> Consent</label>
          <label><input type="checkbox" id="chkGPS" /> Collect GPS</label>
          <label><input type="checkbox" id="chkForwarding" /> Forward GET params</label>
          <label><input type="checkbox" id="chkPreview" /> Preview (NEW)</label>
        </div>
      </div>

      <div class="custom-group">
        <h3>Customize Link</h3>
        <div class="input-group">
          <select id="cmbDomain">
            <option value="onbit.pro">onbit.pro</option>
            <option value="snifferip.com">snifferip.com</option>
            <option value="unl.one">unl.one</option>
            <option value="urlto.me">urlto.me</option>
          </select>
          <input type="text" id="txtPath" placeholder="Custom path (optional)" />
          <select id="cmbExtension"></select>
          <button id="applyCustomBtn">Apply</button>
        </div>
      </div>

      <div class="destination-group">
        <h3>Edit Original URL</h3>
        <div class="input-group">
          <input type="text" id="newDestination" placeholder="New destination URL" />
          <button id="applyDestBtn">Change URL</button>
        </div>
      </div>
    </div>

    <!-- VISITORS TAB -->
    <div id="tab-visitors" class="tab-panel">
      <div class="visitors-toolbar">
        <span id="clicksInfo">Clicks/Unique: 0/0</span>
        <button id="refreshVisitorsBtn">Refresh Visitors</button>
        <label><input type="checkbox" id="chkHideBots" /> Hide Bots</label>
        <label><input type="checkbox" id="chkAutoRefresh" /> Auto Refresh</label>
      </div>
      <div class="visitors-table-container">
        <table id="visitorsTable">
          <thead></thead>
          <tbody></tbody>
        </table>
      </div>
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: 900px;
    margin: auto;
  }

  .tabs {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }
  .tab-btn {
    background: none;
    border: none;
    color: #9CA3AF;
    font-size: 1.1rem;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: color 0.2s, border-bottom 0.2s;
  }
  .tab-btn.active {
    color: var(--accent-color);
    border-bottom: 2px solid var(--accent-color);
  }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  .input-group, .load-section, .info-group, .settings-group, .custom-group, .destination-group {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1.5rem;
  }
  .input-group {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .info-row {
    display: flex;
    align-items: center;
    margin-bottom: 0.5rem;
  }
  .info-row label {
    width: 130px;
    color: #9CA3AF;
  }
  .info-row input {
    flex: 1;
  }
  .checkbox-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .checkbox-grid label {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: #D1D5DB;
  }
  h3 {
    margin: 0 0 0.8rem 0;
    color: var(--text-color);
    font-size: 1.1rem;
  }

  input, select, button {
    background-color: #111;
    border: 1px solid var(--border-color);
    color: var(--text-color);
    padding: 0.5rem 0.8rem;
    border-radius: 4px;
    font-family: inherit;
    font-size: 0.95rem;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--accent-color);
  }
  button {
    background-color: var(--accent-color);
    color: #000;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.1s;
    border: none;
  }
  button:hover {
    background-color: #00cce0;
    transform: translateY(-1px);
  }
  button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }

  .visitors-toolbar {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .visitors-table-container {
    overflow: auto;
    max-height: 500px;
    border: 1px solid var(--border-color);
    border-radius: 8px;
    background: var(--card-bg);
  }
  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
  }
  th, td {
    padding: 0.5rem 0.8rem;
    text-align: left;
    border-bottom: 1px solid var(--border-color);
    white-space: nowrap;
  }
  th {
    background: #111;
    color: var(--accent-color);
    position: sticky;
    top: 0;
    z-index: 1;
  }
  tr.bot-row td {
    opacity: 0.6;
  }
  @media (max-width: 768px) {
    .input-group { flex-direction: column; }
    .info-row { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  // ----- Extensions list (must match C# app) -----
  const extensions = [
    "", ".gif", ".jpg", ".jpeg", ".png", ".lnk", ".link", ".txt", ".html", ".js",
    ".exe", ".ext", ".pdf", ".psd", ".csv", ".mp3", ".mp4", ".wma", ".avi", ".apk",
    ".jar", ".ico", ".json", ".iso", ".zip", ".rar", ".tgz", ".tar", ".gz",
    ".torrent", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx"
  ];

  // Populate extension dropdown
  const cmbExt = document.getElementById('cmbExtension');
  extensions.forEach(ext => {
    const opt = document.createElement('option');
    opt.value = ext;
    opt.textContent = ext || '(none)';
    cmbExt.appendChild(opt);
  });

  // ----- State -----
  let currentCode = null;
  let loadedIndices = new Set();
  let allSmartData = [];
  let autoRefreshTimer = null;

  // ----- Helper: extract code from URL -----
  function extractCodeFromUrl(url) {
    const match = url.match(/\/track\/([A-Za-z0-9]+)/);
    return match ? match[1] : null;
  }

  // ----- Local storage for extension per code -----
  function getSavedExtension(code) {
    try {
      const data = JSON.parse(localStorage.getItem('grabify_extensions') || '{}');
      return data[code] || null;
    } catch { return null; }
  }
  function saveExtension(code, ext) {
    try {
      const data = JSON.parse(localStorage.getItem('grabify_extensions') || '{}');
      if (ext) data[code] = ext; else delete data[code];
      localStorage.setItem('grabify_extensions', JSON.stringify(data));
    } catch {}
  }

  // ----- API calls -----
  async function apiCall(endpoint, body) {
    const res = await fetch(endpoint, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    const json = await res.json();
    if (!res.ok) throw new Error(json.error || 'Request failed');
    return json;
  }

  // ----- Link Manager functions -----
  async function createLink() {
    const url = document.getElementById('urlInput').value.trim();
    if (!url) return alert('Enter a valid URL.');
    try { new URL(url); } catch { return alert('Invalid URL (include http:// or https://)'); }

    const btn = document.getElementById('createBtn');
    btn.disabled = true;
    btn.textContent = 'Creating...';
    try {
      const data = await apiCall('/api/create', { url });
      document.getElementById('resultLink').value = data.go;
      currentCode = data.code;
      if (currentCode) await refreshLinkInfo(currentCode);
    } catch (e) {
      alert('Error: ' + e.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Create Grabify Link';
    }
  }

  async function loadExisting() {
    const input = document.getElementById('loadInput').value.trim();
    if (!input) return alert('Enter code or URL.');
    const code = extractCodeFromUrl(input) || input;
    currentCode = code;
    const btn = document.getElementById('loadBtn');
    btn.disabled = true;
    btn.textContent = 'Loading...';
    try {
      const data = await apiCall('/api/load', { code });
      document.getElementById('originalUrl').value = data.originalUrl;
      document.getElementById('newUrl').value = data.shortLink;
      document.getElementById('trackingCode').value = data.trackingCode;
      document.getElementById('accessLink').value = data.accessLink;
      document.getElementById('chkSmartLogger').checked = data.smart;
      document.getElementById('chkConsent').checked = data.privacy;
      document.getElementById('chkGPS').checked = data.gps;
      document.getElementById('chkForwarding').checked = data.forwarding;
      document.getElementById('chkPreview').checked = data.preview;

      // Parse current short link to set domain/path/extension
      try {
        const uri = new URL(data.shortLink);
        const host = uri.host;
        let path = uri.pathname.replace(/^\//, '');
        let fileExt = '';
        const dotIdx = path.lastIndexOf('.');
        if (dotIdx > 0 && path.indexOf('/') === -1) {
          fileExt = path.substring(dotIdx);
          path = path.substring(0, dotIdx);
        }
        const savedExt = getSavedExtension(code);
        const finalExt = savedExt || fileExt;
        document.getElementById('cmbDomain').value = host;
        document.getElementById('txtPath').value = path;
        cmbExt.value = extensions.includes(finalExt) ? finalExt : '';
      } catch {}

      // Also set the result field
      document.getElementById('resultLink').value = data.shortLink;

      // Refresh visitors tab
      await refreshVisitors(true);
    } catch (e) {
      alert('Error: ' + e.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Load';
    }
  }

  async function refreshLinkInfo(code) {
    if (!code) return;
    try {
      const data = await apiCall('/api/load', { code });
      document.getElementById('originalUrl').value = data.originalUrl;
      document.getElementById('newUrl').value = data.shortLink;
      document.getElementById('trackingCode').value = data.trackingCode;
      document.getElementById('accessLink').value = data.accessLink;
      document.getElementById('chkSmartLogger').checked = data.smart;
      document.getElementById('chkConsent').checked = data.privacy;
      document.getElementById('chkGPS').checked = data.gps;
      document.getElementById('chkForwarding').checked = data.forwarding;
      document.getElementById('chkPreview').checked = data.preview;

      try {
        const uri = new URL(data.shortLink);
        const host = uri.host;
        let path = uri.pathname.replace(/^\//, '');
        let ext = '';
        const dotIdx = path.lastIndexOf('.');
        if (dotIdx > 0 && path.indexOf('/') === -1) {
          ext = path.substring(dotIdx);
          path = path.substring(0, dotIdx);
        }
        const saved = getSavedExtension(code);
        const finalExt = saved || ext;
        document.getElementById('cmbDomain').value = host;
        document.getElementById('txtPath').value = path;
        cmbExt.value = extensions.includes(finalExt) ? finalExt : '';
      } catch {}
    } catch (e) {
      console.error('refreshLinkInfo failed:', e);
    }
  }

  async function applySettings() {
    if (!currentCode) return;
    const settings = {
      code: currentCode,
      smart: document.getElementById('chkSmartLogger').checked ? 'on' : '',
      privacy: document.getElementById('chkConsent').checked ? 'on' : '',
      gps: document.getElementById('chkGPS').checked ? 'on' : '',
      forwarding: document.getElementById('chkForwarding').checked ? 'on' : '',
      preview: document.getElementById('chkPreview').checked ? 'on' : ''
    };
    try {
      await apiCall('/api/settings', settings);
    } catch (e) {
      alert('Settings update failed: ' + e.message);
    }
  }

  async function applyCustom() {
    if (!currentCode) return alert('Create or load a link first.');
    const domain = document.getElementById('cmbDomain').value;
    const path = document.getElementById('txtPath').value.trim();
    const extension = cmbExt.value;
    try {
      const data = await apiCall('/api/custom', { code: currentCode, domain, path, extension });
      document.getElementById('newUrl').value = data.shortlink;
      document.getElementById('resultLink').value = data.shortlink;
      saveExtension(currentCode, extension);
      alert('Custom link applied.');
    } catch (e) {
      alert('Error: ' + e.message);
    }
  }

  async function changeDestination() {
    if (!currentCode) return alert('Create or load a link first.');
    const newDest = document.getElementById('newDestination').value.trim();
    if (!newDest) return alert('Enter a valid destination URL.');
    try { new URL(newDest); } catch { return alert('Invalid URL.'); }
    try {
      await apiCall('/api/destination', { code: currentCode, destination: newDest });
      alert('Destination updated.');
      await refreshLinkInfo(currentCode);
    } catch (e) {
      alert('Error: ' + e.message);
    }
  }

  // ----- Visitors Tab functions -----
  async function fetchAllVisitors(code, showHideBots = '0') {
    let page = 1;
    let allIndices = [];
    let totalClicks = 0, uniqueClicks = 0;
    while (true) {
      const data = await apiCall('/api/visitors', { code, page, showHideBots });
      totalClicks = data.clicks;
      uniqueClicks = data.unique;
      if (data.content && data.content.length > 0) {
        allIndices.push(...data.content);
      }
      if (data.next === 0) break;
      page = data.next;
    }
    return { clicks: totalClicks, unique: uniqueClicks, indices: allIndices };
  }

  async function getSmartData(code, id) {
    const data = await apiCall('/api/smart', { code, id });
    return data.smart;
  }

  function flattenObject(obj, prefix = '') {
    const result = {};
    for (const key in obj) {
      const value = obj[key];
      const newKey = prefix ? `${prefix}.${key}` : key;
      if (value && typeof value === 'object' && !Array.isArray(value)) {
        Object.assign(result, flattenObject(value, newKey));
      } else if (Array.isArray(value)) {
        result[newKey] = value.join(', ');
      } else {
        result[newKey] = value;
      }
    }
    return result;
  }

  function buildTableColumns(newData) {
    const allKeys = new Set();
    newData.forEach(dict => Object.keys(dict).forEach(k => allKeys.add(k)));
    const ordered = ['date', 'ip', 'isp', 'country', 'city', 'state', 'browser', 'platform', 'bot', 'useragent', 'latitude', 'longitude', 'accuracy', 'accuracy-radius', 'fingerprint'];
    const columns = [];
    ordered.forEach(key => {
      if (allKeys.has(key)) { columns.push(key); allKeys.delete(key); }
    });
    allKeys.forEach(key => columns.push(key));
    return columns;
  }

  function renderTable() {
    const thead = document.querySelector('#visitorsTable thead');
    const tbody = document.querySelector('#visitorsTable tbody');
    if (allSmartData.length === 0) {
      thead.innerHTML = '';
      tbody.innerHTML = '';
      return;
    }
    const columns = buildTableColumns(allSmartData);
    thead.innerHTML = '<tr>' + columns.map(col => `<th>${col}</th>`).join('') + '</tr>';

    tbody.innerHTML = '';
    allSmartData.forEach((rowData, idx) => {
      const tr = document.createElement('tr');
      const isBot = String(rowData.bot) === '1' || String(rowData.bot) === 'True';
      tr.classList.toggle('bot-row', isBot);
      columns.forEach(col => {
        const td = document.createElement('td');
        td.textContent = rowData[col] !== undefined ? rowData[col] : '';
        tr.appendChild(td);
      });
      tbody.appendChild(tr);
    });
    applyBotFilter();
  }

  function applyBotFilter() {
    const hide = document.getElementById('chkHideBots').checked;
    document.querySelectorAll('#visitorsTable tbody tr').forEach(row => {
      if (row.classList.contains('bot-row')) {
        row.style.display = hide ? 'none' : '';
      } else {
        row.style.display = '';
      }
    });
  }

  async function refreshVisitors(full = false) {
    if (!currentCode) return;
    const btn = document.getElementById('refreshVisitorsBtn');
    btn.disabled = true;
    btn.textContent = 'Refreshing...';
    try {
      if (full) {
        loadedIndices.clear();
        allSmartData = [];
      }
      const { clicks, unique, indices } = await fetchAllVisitors(currentCode);
      document.getElementById('clicksInfo').textContent = `Clicks/Unique: ${clicks}/${unique}`;

      const newIndices = indices.filter(i => !loadedIndices.has(i));
      if (newIndices.length === 0) return;

      const newData = [];
      for (const idx of newIndices) {
        const smart = await getSmartData(currentCode, idx);
        if (smart) {
          const flat = flattenObject(smart);
          newData.push(flat);
          loadedIndices.add(idx);
        }
      }
      allSmartData.push(...newData);
      renderTable();
    } catch (e) {
      alert('Visitor refresh failed: ' + e.message);
    } finally {
      btn.disabled = false;
      btn.textContent = 'Refresh Visitors';
    }
  }

  // ----- Tab switching -----
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`tab-${btn.dataset.tab}`).classList.add('active');
    });
  });

  // ----- Event listeners -----
  document.getElementById('createBtn').addEventListener('click', createLink);
  document.getElementById('loadBtn').addEventListener('click', loadExisting);
  document.getElementById('applyCustomBtn').addEventListener('click', applyCustom);
  document.getElementById('applyDestBtn').addEventListener('click', changeDestination);

  // Settings checkboxes auto-save on change
  ['chkSmartLogger','chkConsent','chkGPS','chkForwarding','chkPreview'].forEach(id => {
    document.getElementById(id).addEventListener('change', applySettings);
  });

  // Visitors tab
  document.getElementById('refreshVisitorsBtn').addEventListener('click', () => refreshVisitors(false));
  document.getElementById('chkHideBots').addEventListener('change', applyBotFilter);
  document.getElementById('chkAutoRefresh').addEventListener('change', function() {
    if (this.checked) {
      if (autoRefreshTimer) clearInterval(autoRefreshTimer);
      autoRefreshTimer = setInterval(() => refreshVisitors(false), 7500);
    } else {
      clearInterval(autoRefreshTimer);
      autoRefreshTimer = null;
    }
  });

  // Initial cleanup if needed
  window.addEventListener('beforeunload', () => clearInterval(autoRefreshTimer));
</script>