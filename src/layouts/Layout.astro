---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>Grabify Manager | Mastercodeon</title>
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <ClientRouter />
    </head>
    <body>
        <header>
            <button class="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="main-nav">
                <span class="line"></span>
                <span class="line"></span>
                <span class="line"></span>
            </button>
            <nav id="main-nav">
                <a href="/">Home</a>
            </nav>
        </header>
        <div class="overlay"></div>
        <slot />
    </body>
</html>

<style>
  header {
    max-width: 800px;
    margin: 0 auto 2rem auto;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border-color);
  }

  nav {
    display: flex;
    gap: 1.5rem;
    font-size: 1.1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hamburger, .overlay {
    display: none;
  }

  @media (max-width: 768px) {
    header {
      border-bottom: none;
      padding-bottom: 0;
      margin-bottom: 1.5rem;
      max-width: 100%;
    }

    nav {
      position: fixed;
      top: 0;
      left: 0;
      width: fit-content;
      min-width: 200px;
      height: 100%;
      background-color: var(--card-bg);
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      padding: 6rem 3rem 2rem 1.5rem;
      gap: 2rem;
      transform: translateX(-100%);
      transition: transform 0.3s ease-in-out;
      z-index: 1000;
      border-right: 1px solid var(--border-color);
    }

    nav.is-open {
      transform: translateX(0);
    }

    .hamburger {
      display: block;
      background: none;
      border: none;
      cursor: pointer;
      padding: 15px;
      position: relative;
      z-index: 1001;
    }

    .hamburger .line {
      display: block;
      width: 25px;
      height: 3px;
      background-color: var(--text-color);
      margin: 5px 0;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .overlay {
        display: block;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease-in-out;
    }

    .overlay.is-open {
        opacity: 1;
        pointer-events: auto;
    }
  }
</style>

<script>
  function setupNav() {
    const hamburger = document.querySelector('.hamburger');
    const nav = document.querySelector('#main-nav');
    const overlay = document.querySelector('.overlay');
    const navLinks = nav.querySelectorAll('a');

    const toggleMenu = () => {
      const isOpen = nav.classList.toggle('is-open');
      overlay.classList.toggle('is-open', isOpen);
      hamburger.setAttribute('aria-expanded', isOpen);
    };

    if (hamburger && nav && overlay) {
      hamburger.replaceWith(hamburger.cloneNode(true));
      overlay.replaceWith(overlay.cloneNode(true));
      const newHamburger = document.querySelector('.hamburger');
      const newOverlay = document.querySelector('.overlay');
      newHamburger.addEventListener('click', toggleMenu);
      newOverlay.addEventListener('click', toggleMenu);
      navLinks.forEach(link => {
        link.addEventListener('click', () => {
          if (nav.classList.contains('is-open')) toggleMenu();
        });
      });
    }
  }

  document.addEventListener('astro:page-load', setupNav);
</script>